# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# Google Sheet ID for the live Form Responses
VITE_RESPONSES_SHEET_ID=

# Google Sheet ID for the backend (tracker, config, follow-ups, etc.)
VITE_BACKEND_SHEET_ID=

# Domain gate for OAuth (only this domain may sign in)
VITE_DOMAIN_ALLOWLIST=gazaskygeeks.com

# App title shown in the UI
VITE_APP_TITLE="Advisor Pipeline"
